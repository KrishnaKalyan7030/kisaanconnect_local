# Database (we will use SQLite first for simplicity, later you can change to PostgreSQL)
DATABASE_URL=sqlite:///./kisaan.db

# Security
SECRET_KEY=supersecretkeychangeinproduction1234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional later (for SMS alerts to farmers)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890