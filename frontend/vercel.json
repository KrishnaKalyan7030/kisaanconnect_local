{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/dashboard/farmer", "destination": "/dashboard/farmer/index.html" },
    { "source": "/dashboard/buyer", "destination": "/dashboard/buyer/index.html" },
    { "source": "/dashboard/farmer/add_products", "destination": "/dashboard/farmer/add_products.html" },
    { "source": "/dashboard/farmer/my_products", "destination": "/dashboard/farmer/my_products.html" }
  ],
  "routes": [
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*)\\.html", "dest": "/$1.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}